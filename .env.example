# ── Blockchain ────────────────────────────────────────────────────
# Local Hardhat node (default) — change to Sepolia RPC for testnet
WEB3_PROVIDER_URL=http://127.0.0.1:7545

# Deployed contract address (filled in after running deploy.py)
CONTRACT_ADDRESS=0xYourContractAddressHere

# Chain ID: 1337 = Hardhat local | 11155111 = Sepolia testnet
CHAIN_ID=5777

# ── Deployer ──────────────────────────────────────────────────────
# Used only during deployment — never commit real keys!
DEPLOYER_ADDRESS=0x36435Ce5df72c6BA6790B51dbfd84896BEb633A3
DEPLOYER_PRIVATE_KEY=0xcaf6aeccb9786b8bf6f41ac523f09db115721f9c9453e3c80b43decac0fdfd6a
